{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.json",
      "use": "@vercel/static"
    },
    {
      "src": "*.webmanifest",
      "use": "@vercel/static"
    },
    {
      "src": "*.xml",
      "use": "@vercel/static"
    },
    {
      "src": "*.txt",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/charte",
      "destination": "/charte.html"
    },
    {
      "source": "/reservation",
      "destination": "/reservation.html"
    },
    {
      "source": "/contenu",
      "destination": "/contenu.html"
    },
    {
      "source": "/antifraude",
      "destination": "/antifraude.html"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/annonce/:id",
      "destination": "/index.html"
    },
    {
      "source": "/agence/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/agent/:id",
      "destination": "/index.html"
    },
    {
      "source": "/promoteur/:id",
      "destination": "/index.html"
    },
    {
      "source": "/guide/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/logo-avatar.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logo-white.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logo-symbol.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logo-icon.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logo-dark.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logo-nav.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logo.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "image/webp"
        }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self), payment=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.gstatic.com https://browser.sentry-cdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://rgwozhjpufgebaiygvhr.supabase.co https://images.unsplash.com https://lh3.googleusercontent.com https://flagcdn.com https://tile.openstreetmap.org https://api.maptiler.com https://a.tile.openstreetmap.org https://b.tile.openstreetmap.org https://c.tile.openstreetmap.org; connect-src 'self' https://rgwozhjpufgebaiygvhr.supabase.co wss://rgwozhjpufgebaiygvhr.supabase.co https://o4511124074332160.ingest.de.sentry.io https://api.resend.com https://nominatim.openstreetmap.org https://exchange-api.kerjom.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=60, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/api/docs",
      "destination": "https://kerjom-seo.vercel.app/api/docs",
      "permanent": false
    },
    {
      "source": "/agences/(.*)",
      "destination": "https://kerjom-seo.vercel.app/agences/$1",
      "permanent": false
    },
    {
      "source": "/annonces",
      "destination": "https://kerjom-seo.vercel.app/annonces",
      "permanent": false
    },
    {
      "source": "/annonces/(.*)",
      "destination": "https://kerjom-seo.vercel.app/annonces/$1",
      "permanent": false
    },
    {
      "source": "/guides",
      "destination": "https://kerjom-seo.vercel.app/guides",
      "permanent": false
    },
    {
      "source": "/guides/(.*)",
      "destination": "https://kerjom-seo.vercel.app/guides/$1",
      "permanent": false
    },
    {
      "source": "/tarifs",
      "destination": "https://kerjom-seo.vercel.app/tarifs",
      "permanent": false
    },
    {
      "source": "/marche",
      "destination": "https://kerjom-seo.vercel.app/marche",
      "permanent": false
    },
    {
      "source": "/promoteurs",
      "destination": "https://kerjom-seo.vercel.app/promoteurs",
      "permanent": false
    },
    {
      "source": "/agences",
      "destination": "https://kerjom-seo.vercel.app/agences",
      "permanent": false
    },
    {
      "source": "/agents",
      "destination": "https://kerjom-seo.vercel.app/agents",
      "permanent": false
    },
    {
      "source": "/bien-verifie",
      "destination": "https://kerjom-seo.vercel.app/bien-verifie",
      "permanent": false
    },
    {
      "source": "/contact",
      "destination": "https://kerjom-seo.vercel.app/contact",
      "permanent": false
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://kerjom-seo.vercel.app/sitemap.xml",
      "permanent": false
    },
    {
      "source": "/robots.txt",
      "destination": "https://kerjom-seo.vercel.app/robots.txt",
      "permanent": false
    }
  ]
}
